# ===============================================
# 1. Maven 构建产物 (必须忽略)
# ===============================================
# 忽略所有模块下的 target 目录
# 您的结构中包含: web-ai-project01/tlias-web-management/target/
target/

# ===============================================
# 2. IntelliJ IDEA 配置文件 (必须忽略)
# ===============================================
# 忽略项目特定的配置文件夹
.idea/

# 忽略模块文件 (您的结构中包含 web-ai-project01.iml)
*.iml

# 忽略工作区文件
*.iws
*.ipr

# ===============================================
# 3. 其他 IDE 配置文件 (建议忽略，防止团队冲突)
# ===============================================
# Eclipse
.classpath
.project
.settings/

# VS Code
.vscode/

# ===============================================
# 4. 操作系统生成的文件 (垃圾文件)
# ===============================================
# Mac 系统
.DS_Store

# Windows 系统
Thumbs.db
desktop.ini

# ===============================================
# 5. 日志文件
# ===============================================
*.log